PORT=8000
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Default to the local Granite GGUF via llama.cpp.
# Optional alternatives: openai-compatible for hosted inference, template for UI demos.
GENERATION_PROVIDER=llama
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

MODEL_PATH=backend/models/granite-4.1-3b-q4_k_m.gguf
DESIGN_SYSTEM_PATH=design-system.json

LLAMA_CONTEXT_SIZE=4096
LLAMA_THREADS=4
LLAMA_GPU_LAYERS=0
LLAMA_MAX_TOKENS=900
LLAMA_TEMPERATURE=0.1

PREVIEW_COMPILE_VALIDATE=true
PREVIEW_COMPILE_MODE=tsc
PREVIEW_COMPILE_TIMEOUT_SECONDS=20

# Production topology knobs. Local development can leave these empty.
INFERENCE_QUEUE_URL=
MODEL_WARM_POOL_SIZE=1
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=component-architect-backend
